# 获取Android外部存储路径
def get_external_storage_path():
    """获取Android外部存储路径"""
    # 尝试多种方式获取Android外部存储路径
    possible_paths = [
        "/storage/emulated/0",
        "/sdcard",
        "/mnt/sdcard",
        os.path.expanduser("~"),
        "/data/data/com.termux/files/home/storage/shared",  # Termux路径
        "/sdcard/Download",  # 下载目录
        os.path.dirname(os.path.abspath(__file__)),  # 当前脚本目录
    ]
    
    for path in possible_paths:
        if os.path.exists(path):
            print(f"检测到路径存在: {path}")
            return path
    
    # 如果都失败，返回当前工作目录
    current_dir = os.getcwd()
    print(f"所有预设路径都不存在，使用当前目录: {current_dir}")
    return current_dir

# 安卓特定的文件路径处理
class AndroidFileHandler:
    def __init__(self):
        self.base_path = get_external_storage_path()
        print(f"使用存储路径: {self.base_path}")
        print(f"存储路径存在: {os.path.exists(self.base_path)}")
        
        # 列出该目录下的文件和文件夹
        if os.path.exists(self.base_path):
            print(f"目录内容:")
            try:
                items = os.listdir(self.base_path)[:10]  # 只显示前10个
                for item in items:
                    item_path = os.path.join(self.base_path, item)
                    if os.path.isdir(item_path):
                        print(f"  [目录] {item}")
                    else:
                        print(f"  [文件] {item}")
            except Exception as e:
                print(f"无法列出目录内容: {e}")
    
    def get_full_path(self, relative_path):
        """获取完整路径"""
        # 清理路径中的..和.
        normalized = os.path.normpath(relative_path)
        full_path = os.path.join(self.base_path, normalized)
        print(f"完整路径: {full_path}")
        print(f"完整路径存在: {os.path.exists(full_path)}")
        return full_path
    
    def ensure_dir_exists(self, file_path):
        """确保目录存在"""
        dir_path = os.path.dirname(file_path)
        if not os.path.exists(dir_path):
            print(f"创建目录: {dir_path}")
            try:
                os.makedirs(dir_path, exist_ok=True)
                print(f"目录创建成功: {os.path.exists(dir_path)}")
            except Exception as e:
                print(f"目录创建失败: {e}")
        else:
            print(f"目录已存在: {dir_path}")
        return file_path

