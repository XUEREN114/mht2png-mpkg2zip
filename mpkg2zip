# 缓冲区大小（1MB）
BUFFER_SIZE = 1024 * 1024

def read_int(file_obj):
    """读取4字节整数（小端序）"""
    try:
        data = file_obj.read(4)
        if len(data) < 4:
            return None
        
        # 安卓上通常是小端序
        return struct.unpack('<I', data)[0]
    except Exception as e:
        print(f"读取整数时出错: {e}")
        return None

def read_string(file_obj):
    """读取字符串（先读长度，再读内容）"""
    try:
        # 读取字符串长度
        str_len = read_int(file_obj)
        if str_len is None or str_len <= 0:
            return None
        
        # 限制最大长度防止内存溢出
        MAX_STRING_LENGTH = 10 * 1024 * 1024  # 10MB（不是10GB）
        if str_len > MAX_STRING_LENGTH:
            print(f"警告: 字符串长度过长 ({str_len} bytes)，限制为 {MAX_STRING_LENGTH}")
            str_len = MAX_STRING_LENGTH
        
        # 读取字符串内容
        buffer = bytearray()
        bytes_read = 0
        
        while bytes_read < str_len:
            chunk_size = min(BUFFER_SIZE, str_len - bytes_read)
            chunk = file_obj.read(chunk_size)
            if not chunk:
                break
            buffer.extend(chunk)
            bytes_read += len(chunk)
        
        # 尝试解码为UTF-8
        try:
            return buffer.decode('utf-8')
        except UnicodeDecodeError:
            # 如果UTF-8失败，尝试GBK（中文编码）
            try:
                return buffer.decode('gbk')
            except:
                # 最后返回原始字节的字符串表示
                try:
                    return buffer.decode('utf-8', errors='ignore')
                except:
                    return str(buffer[:100])  # 限制长度
        
    except Exception as e:
        print(f"读取字符串时出错: {e}")
        return None

def copy_stream_to_zip(zip_file, source_file, entry_name, data_length):
    """将数据流复制到ZIP文件中（支持大文件）"""
    try:
        # 确保entry_name是字符串
        if isinstance(entry_name, bytes):
            entry_name = entry_name.decode('utf-8', errors='ignore')
        
        # 在安卓上，确保路径分隔符正确
        entry_name = entry_name.replace('\\', '/')
        
        total_read = 0
        buffer_size = min(BUFFER_SIZE, data_length)
        
        # 使用zipfile的writestr方法分块写入
        zip_info = zipfile.ZipInfo(entry_name)
        zip_info.compress_type = zipfile.ZIP_DEFLATED
        
        # 创建写入器
        with zip_file.open(zip_info, 'w') as entry:
            while total_read < data_length:
                remaining = data_length - total_read
                chunk_size = min(BUFFER_SIZE, remaining)
                
                # 读取数据
                chunk = source_file.read(chunk_size)
                if not chunk:
                    break
                
                # 写入ZIP
                entry.write(chunk)
                total_read += len(chunk)
                
                # 显示进度（每10MB更新一次）
                if total_read % (10 * BUFFER_SIZE) == 0:
                    progress_pct = (total_read / data_length) * 100
                    print(f"处理中: {entry_name} - "
                          f"{progress_pct:.1f}% ({total_read}/{data_length} bytes)")
        
        return total_read
        
    except Exception as e:
        print(f"复制流到ZIP时出错: {e}")
        return 0

def convert_mpkg_to_zip():
    """主转换函数"""
    print("\n" + "=" * 50)
    print("MPKG 到 ZIP 转换器")
    print("=" * 50)
    
    # 再次确认输入文件是否存在
    if not os.path.exists(input_file):
        print(f"错误: 输入文件不存在: {input_file}")
        print(f"当前工作目录: {os.getcwd()}")
        return False
    
    input_size = os.path.getsize(input_file)
    print(f"输入文件: {input_file}")
    print(f"输出文件: {output_file}")
    
    # 根据文件大小选择合适的单位
    if input_size >= 1024*1024*1024:  # 大于1GB
        size_str = f"{input_size / (1024*1024*1024):.2f} GB"
    else:
        size_str = f"{input_size / (1024*1024):.2f} MB"
    
    print(f"输入文件大小: {size_str}")
    print(f"开始转换...")
    print("-" * 50)
    
    try:
        with open(input_file, 'rb') as fis:
            # 创建ZIP文件（使用ZIP64支持大文件）
            with zipfile.ZipFile(output_file, 'w', zipfile.ZIP_DEFLATED, allowZip64=True) as zos:
                # 读取版本号
                version_str = read_string(fis)
                if version_str:
                    print(f"版本号: {version_str}")
                else:
                    print("警告: 无法读取版本号，可能不是有效的MPKG文件")
                
                # 读取文件数量
                file_count = read_int(fis)
                if not file_count or file_count <= 0:
                    print("错误: 无效的文件数量")
                    return False
                
                print(f"文件数量: {file_count}")
                print("-" * 50)
                
                # 存储文件信息
                file_table = []
                size_table = []
                
                # 读取文件索引
                for i in range(file_count):
                    print(f"读取文件索引 {i+1}/{file_count}...")
                    
                    file_name = read_string(fis)
                    if not file_name:
                        print(f"错误: 无法读取文件名 #{i+1}")
                        break
                    
                    # 跳过未知字段（4字节）
                    _ = read_int(fis)
                    
                    file_size = read_int(fis)
                    if not file_size:
                        print(f"错误: 无法读取文件大小 #{i+1}")
                        break
                    
                    # 存储文件信息
                    file_table.append(file_name)
                    size_table.append(file_size)
                    
                    # 根据文件大小选择合适的单位显示
                    if file_size >= 1024*1024*1024:
                        size_display = f"{file_size / (1024*1024*1024):.2f} GB"
                    else:
                        size_display = f"{file_size / (1024*1024):.2f} MB"
                    
                    print(f"  {i+1:3d}. {file_name[:50]}{'...' if len(file_name) > 50 else ''}")
                    print(f"      大小: {size_display}")
                
                if len(file_table) != file_count:
                    print(f"警告: 只读取了 {len(file_table)}/{file_count} 个文件索引")
                
                print("-" * 50)
                print("开始提取文件...")
                print("-" * 50)
                
                # 处理文件数据
                success_count = 0
                for i, (file_name, file_size) in enumerate(zip(file_table, size_table)):
                    print(f"[{i+1}/{len(file_table)}] 提取: {file_name}")
                    
                    processed = copy_stream_to_zip(zos, fis, file_name, file_size)
                    
                    if processed == file_size:
                        success_count += 1
                        print(f"  ✓ 成功 ({processed}/{file_size} bytes)")
                    else:
                        print(f"  ✗ 失败: 只读取了 {processed}/{file_size} bytes")
                    
                    # 在安卓上，定期刷新输出
                    if (i + 1) % 10 == 0:
                        sys.stdout.flush()
                
                print("-" * 50)
                print(f"转换完成!")
                print(f"成功提取: {success_count}/{len(file_table)} 个文件")
                
                # 检查输出文件
                if os.path.exists(output_file):
                    output_size = os.path.getsize(output_file)
                    
                    # 根据输出文件大小选择合适的单位
                    if output_size >= 1024*1024*1024:
                        output_size_str = f"{output_size / (1024*1024*1024):.2f} GB"
                    else:
                        output_size_str = f"{output_size / (1024*1024):.2f} MB"
                    
                    print(f"输出文件大小: {output_size_str}")
                
                return success_count == len(file_table)
                
    except Exception as e:
        print(f"转换过程中出错: {e}")
        import traceback
        traceback.print_exc()
        return False

def main():
    """主函数"""
    print("Android MPKG转换工具")
    print("=" * 50)
    
    # 开始转换
    start_time = time.time()
    
    if convert_mpkg_to_zip():
        print("✓ 转换成功完成!")
    else:
        print("✗ 转换过程中出现问题")
    
    elapsed_time = time.time() - start_time
    
    # 格式化耗时显示
    if elapsed_time > 3600:
        hours = int(elapsed_time // 3600)
        minutes = int((elapsed_time % 3600) // 60)
        seconds = elapsed_time % 60
        time_str = f"{hours}小时{minutes}分钟{seconds:.1f}秒"
    elif elapsed_time > 60:
        minutes = int(elapsed_time // 60)
        seconds = elapsed_time % 60
        time_str = f"{minutes}分钟{seconds:.1f}秒"
    else:
        time_str = f"{elapsed_time:.2f}秒"
    
    print(f"总耗时: {time_str}")
    print("=" * 50)
    
    # 在安卓上，保持终端打开
    if 'ANDROID_ARGUMENT' in os.environ:
        print("\n按Enter键退出...")
        input()
    else:
        print("\n转换完成，按任意键退出...")
        input()

if __name__ == "__main__":
    main()